{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantsmith.dev/contracts/clearing_diagnostics.schema.json",
  "title": "Clearing Structural Diagnostics List",
  "description": "project_data/reports/runs/r{run_id}/data/clearing_diagnostics.json: 当前 run 内每个品种的结构诊断聚合（成本后指标、exit reason 分布、原始 R 与 MAE/MFE 分布）。由 report 聚合层消费 trade_clearings 生成，不重新计算账务。前端结构诊断视图消费。",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "backtest_id",
      "symbol",
      "trade_count"
    ],
    "properties": {
      "backtest_id": {"type": "integer", "minimum": 1},
      "symbol": {"type": "string", "minLength": 1},
      "trade_count": {"type": "integer", "minimum": 0},
      "total_net_pnl": {"type": "number"},
      "cost_adjusted_win_rate": {"type": "number"},
      "cost_adjusted_payoff_ratio": {"type": "number"},
      "breakeven_win_rate": {"type": "number"},
      "win_rate_margin": {"type": "number"},
      "avg_win": {"type": "number"},
      "avg_loss": {"type": "number"},
      "max_single_loss": {"type": "number"},
      "max_consecutive_losses": {"type": "integer", "minimum": 0},
      "exit_reason_distribution": {
        "type": "object",
        "additionalProperties": {"type": "integer", "minimum": 0}
      },
      "raw_account_r_multiples": {
        "type": "array",
        "items": {"type": "number"}
      },
      "raw_price_r_multiples": {
        "type": "array",
        "items": {"type": "number"}
      },
      "mae_values": {
        "type": "array",
        "items": {"type": "number"}
      },
      "mfe_values": {
        "type": "array",
        "items": {"type": "number"}
      }
    },
    "additionalProperties": true
  }
}
