{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantsmith.dev/contracts/nav.schema.json",
  "title": "Run Navigation Index",
  "description": "output/data/nav.json: 跨 run 汇总列表。前端 r 列表页消费。",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "strategy", "engine", "symbols", "status", "created"],
    "properties": {
      "id": {"type": "integer", "minimum": 1},
      "strategy": {"type": "string", "minLength": 1},
      "engine": {"type": "string", "minLength": 1},
      "symbols": {"type": "integer", "minimum": 0},
      "status": {"type": "string", "minLength": 1},
      "created": {"type": "string", "minLength": 1},
      "use_fixed_seed": {"type": "boolean"},
      "random_seed": {"type": "integer"}
    },
    "additionalProperties": true
  }
}
